							"mode": "raw",
							"raw": "{\n    \"title\": \"Học MongoDB Atlas cùng Express\",\n    \"author\": \"Hoàng Lưu\",\n    \"content\": \"Đây là bài viết đầu tiên được lưu vào database ex29 trên MongoDB Atlas.\",\n    \"comments\": [\n        {\n            \"commenter\": \"Nguyễn Văn A\",\n            \"body\": \"Bài viết rất hay và trực quan!\"\n        }\n    ]\n}",
							"options": {
								"raw": {
									"language": "json"
								}
